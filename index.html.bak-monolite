// ── Form bindings ────────────────────────────────────────────────────────
function setupFormBindings() {
  // Radio inputs (rating tables + ruota)
  document.querySelectorAll('#schedaForm input[type="radio"]').forEach(input => {
    input.addEventListener('change', (e) => {
      const field = e.target.dataset.field; // 'soft' | 'hard' | 'kpi' | 'ruota'
      const idx = e.target.dataset.idx;
      const value = parseInt(e.target.value);
      const fieldMap = { soft: 'softSkills', hard: 'hardSkills', kpi: 'kpi', ruota: 'ruota' };
      const key = fieldMap[field];
      if (!state.scheda[key]) state.scheda[key] = {};
      state.scheda[key][idx] = value;
      scheduleSave();
      updateProgress();
      updateStepperCompletion();
    });
  });

  // Textareas
  document.querySelectorAll('#schedaForm textarea').forEach(ta => {
    ta.addEventListener('input', (e) => {
      const field = e.target.dataset.fieldText;
      state.scheda[field] = e.target.value;
      scheduleSave();
      updateProgress();
    });
  });
}

function fillFormFromState() {
  const s = state.scheda;

  ['softSkills','hardSkills','kpi','ruota'].forEach(key => {
    const prefix = { softSkills:'soft', hardSkills:'hard', kpi:'kpi', ruota:'ruota' }[key];
    Object.entries(s[key] || {}).forEach(([idx, val]) => {
      const radio = document.getElementById(`${prefix}-${idx}-${val}`);
      if (radio) radio.checked = true;
    });
  });

  ['episodiNote','statoAvanzamentoHard','statoAvanzamentoKpi',
   'obiettivoPrioritario','obiettivoSecondario',
   'proposteAzienda','proposteIdea','proposteResponsabile',
   'richiesteAzienda','richiesteColleghi'].forEach(key => {
    const ta = document.querySelector(`textarea[data-field-text="${key}"]`);
    if (ta) ta.value = s[key] || '';
  });

  updateStepperCompletion();
}

// ── Save (debounced) + status ────────────────────────────────────────────
function scheduleSave() {
  setSaveStatus('dirty');
  clearTimeout(state.saveTimer);
  state.saveTimer = setTimeout(() => {
    saveNow();
  }, 800);
}

function manualSave() {
  clearTimeout(state.saveTimer);
  saveNow();
  toast('Bozza salvata');
}

async function saveNow() {
  if (!state.scheda || !state.currentUser) return;
  setSaveStatus('saving');
  state.scheda.updatedAt = Date.now();
  const res = await Storage.saveScheda(state.currentUser.slug, state.year, state.quarter, 'autovalutazione', state.scheda);
  if (res.synced) {
    setSaveStatus('saved');
  } else {
    // Salvato in locale ma non sincronizzato: avviso utente
    setSaveStatus('dirty');
    document.querySelector('#saveStatus .label').textContent = 'Solo in locale (no sync)';
  }
}

function setSaveStatus(kind) {
  const el = document.getElementById('saveStatus');
  if (!el) return;
  el.style.display = 'flex';
  el.className = 'save-status ' + (kind === 'saved' ? '' : kind);
  const labels = { saved: 'Tutto salvato', dirty: 'Modifiche non salvate', saving: 'Salvataggio…' };
  el.querySelector('.label').textContent = labels[kind] || 'Tutto salvato';
}

function showSaveStatus() {
  document.getElementById('saveStatus').style.display = 'flex';
  setSaveStatus('saved');
}

// ── Progress + stepper completion ────────────────────────────────────────
function updateProgress() {
  const s = state.scheda;
  let filled = 0, total = 0;

  total += SOFT_SKILLS.length;
  filled += Object.keys(s.softSkills || {}).length;
  total += HARD_SKILLS_QUADIENT.length;
  filled += Object.keys(s.hardSkills || {}).length;
  total += KPI_OPERATIVE.length;
  filled += Object.keys(s.kpi || {}).length;
  total += RUOTA_MACRO.length;
  filled += Object.keys(s.ruota || {}).length;

  // 10 campi di testo
  const textFields = ['episodiNote','statoAvanzamentoHard','statoAvanzamentoKpi',
    'obiettivoPrioritario','obiettivoSecondario',
    'proposteAzienda','proposteIdea','proposteResponsabile',
    'richiesteAzienda','richiesteColleghi'];
  total += textFields.length;
  filled += textFields.filter(f => (s[f] || '').trim().length > 10).length;

  const pct = Math.round(filled / total * 100);
  const el = document.getElementById('submitProgress');
  if (el) el.innerHTML = 'Compilazione: <b>' + pct + '%</b> · ' + filled + ' / ' + total + ' campi';
}

function updateStepperCompletion() {
  const s = state.scheda;
  const sections = [
    { id: 'sec-01', done: Object.keys(s.softSkills || {}).length >= SOFT_SKILLS.length },
    { id: 'sec-02', done: Object.keys(s.hardSkills || {}).length >= HARD_SKILLS_QUADIENT.length },
    { id: 'sec-03', done: Object.keys(s.kpi || {}).length >= KPI_OPERATIVE.length },
    { id: 'sec-04', done: (s.obiettivoPrioritario || '').length > 10 && (s.obiettivoSecondario || '').length > 10 },
    { id: 'sec-05', done: (s.proposteAzienda || '').length > 10 },
    { id: 'sec-06', done: (s.richiesteAzienda || '').length > 10 },
    { id: 'sec-07', done: Object.keys(s.ruota || {}).length >= RUOTA_MACRO.length }
  ];
  sections.forEach(sec => {
    const item = document.querySelector('.step-item[data-target="' + sec.id + '"]');
    if (item) item.classList.toggle('completed', sec.done);
  });
}

// ── Scroll-spy stepper ───────────────────────────────────────────────────
function setupScrollSpy() {
  if (state.observer) state.observer.disconnect();
  state.observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var id = entry.target.id;
        document.querySelectorAll('.step-item').forEach(function(el) {
          el.classList.toggle('active', el.dataset.target === id);
        });
      }
    });
  }, { rootMargin: '-15% 0px -65% 0px', threshold: 0 });
  document.querySelectorAll('.form-section').forEach(function(s) { state.observer.observe(s); });
}

// ── Submit con conferma ──────────────────────────────────────────────────
function confirmSubmit() {
  var s = state.scheda;
  var incomplete = [];
  if (Object.keys(s.softSkills || {}).length < SOFT_SKILLS.length) incomplete.push('Soft Skills');
  if (Object.keys(s.hardSkills || {}).length < HARD_SKILLS_QUADIENT.length) incomplete.push('Hard Skills');
  if (Object.keys(s.kpi || {}).length < KPI_OPERATIVE.length) incomplete.push('KPI');
  if (Object.keys(s.ruota || {}).length < RUOTA_MACRO.length) incomplete.push('Ruota');

  var modal = document.createElement('div');
  modal.className = 'modal-backdrop';
  var bodyMsg;
  if (incomplete.length > 0) {
    bodyMsg = '<p>Non hai compilato tutte le voci di: <b>' + incomplete.join(', ') +
      '</b>.<br>Vuoi inviare lo stesso? Dopo l&rsquo;invio la scheda non sar&agrave; pi&ugrave; modificabile.</p>';
  } else {
    bodyMsg = '<p>Stai per inviare la scheda. <b>Dopo l&rsquo;invio non potrai pi&ugrave; modificarla.</b><br>Sicuro di voler procedere?</p>';
  }
  modal.innerHTML =
    '<div class="modal-card"><h3>Invio definitivo</h3>' + bodyMsg +
    '<div class="modal-actions">' +
      '<button class="btn-secondary" onclick="this.closest(&quot;.modal-backdrop&quot;).remove()">Annulla</button>' +
      '<button class="btn-primary" onclick="doSubmit(this)">S&igrave;, invia</button>' +
    '</div></div>';
  document.body.appendChild(modal);
}

window.doSubmit = async function(btn) {
  btn.disabled = true;
  state.scheda.submittedAt = Date.now();
  state.scheda.lockedAt = Date.now();
  state.lockedAt = state.scheda.lockedAt;
  await saveNow();
  var modal = document.querySelector('.modal-backdrop');
  if (modal) modal.remove();
  toast('Scheda inviata');
  setTimeout(function() { Router.go(); }, 600);
};
window.manualSave = manualSave;
window.confirmSubmit = confirmSubmit;

// ========================================================================
// VIEW: TEAM (admin)
// ========================================================================
async function renderTeamStub() {
  var u = state.currentUser;
  var team = MOCK_USERS.filter(function(m) {
    return m.role === 'user' && (u.area === 'all' || m.area === u.area);
  });
  var main = document.getElementById('appMain');
  document.getElementById('saveStatus').style.display = 'none';
  main.innerHTML = '<div class="placeholder-page"><h2>Caricamento team…</h2></div>';

  var rows = await Promise.all(team.map(async function(m) {
    var loaded = await Promise.all([
      Storage.loadScheda(m.slug, state.year, state.quarter, 'autovalutazione'),
      Storage.loadScheda(m.slug, state.year, state.quarter, 'valutazione')
    ]);
    var sch = loaded[0], valSch = loaded[1];
    var autoStato = sch.submittedAt ? 'inviata' : (sch.updatedAt ? 'bozza' : 'vuota');
    var valStato  = valSch.submittedAt ? 'inviata' : (valSch.updatedAt ? 'bozza' : 'vuota');
    return { m: m, autoStato: autoStato, valStato: valStato };
  }));
  var lblMap = { vuota: '— Non iniziata', bozza: 'In bozza', inviata: '✓ Inviata' };

  var html = '';
  html += '<div class="page-head">';
  html +=   '<div class="page-eyebrow">Team · ' + state.year + ' · ' + state.quarter + '</div>';
  html +=   '<h1 class="page-title">I tuoi <span class="accent">membri di team</span></h1>';
  html +=   '<p class="page-sub">Area visibile: <b>' + (u.area === 'all' ? 'tutte' : u.area) + '</b></p>';
  html += '</div>';
  html += '<div class="card"><table style="width:100%; border-collapse:collapse;">';
  html +=   '<thead><tr style="border-bottom:2px solid var(--rule-soft);">';
  ['Membro','Area','Autoval','Val resp','Azioni'].forEach(function(h) {
    html += '<th style="text-align:left; padding:14px 8px; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-mute);">' + h + '</th>';
  });
  html +=   '</tr></thead><tbody>';
  rows.forEach(function(r) {
    html += '<tr style="border-bottom:1px solid var(--rule-soft);">';
    html +=   '<td style="padding:14px 8px;"><b>' + r.m.displayName + '</b><br><small style="color:var(--ink-mute);">' + r.m.email + '</small></td>';
    html +=   '<td style="padding:14px 8px;">' + r.m.area + '</td>';
    html +=   '<td style="padding:14px 8px;"><span class="scheda-stato ' + r.autoStato + '">' + lblMap[r.autoStato] + '</span></td>';
    html +=   '<td style="padding:14px 8px;"><span class="scheda-stato ' + r.valStato + '">'  + lblMap[r.valStato]  + '</span></td>';
    html +=   '<td style="padding:14px 8px;">';
    html +=     '<button class="btn-secondary" style="padding:6px 14px; font-size:12px;" disabled title="In arrivo">Valuta</button> ';
    html +=     '<button class="btn-secondary" style="padding:6px 14px; font-size:12px;" disabled title="In arrivo">Colloquio</button>';
    html +=   '</td></tr>';
  });
  html +=   '</tbody></table>';
  if (rows.length === 0) html += '<p style="text-align:center; padding:40px; color:var(--ink-mute);">Nessun membro nella tua area.</p>';
  html += '</div>';
  html += '<p style="margin-top:18px; color:var(--ink-mute); font-size:13px; text-align:center;">I bottoni "Valuta" e "Colloquio" saranno attivi nella prossima iterazione.</p>';
  main.innerHTML = html;
}

// ========================================================================
// DEBUG PANEL — visibile solo a admin/all
// ========================================================================
async function renderDebugPanel() {
  var host = document.getElementById('debugPanelHost');
  if (!host) return;
  host.innerHTML =
    '<div class="debug-panel">' +
      '<h3>Debug Firebase &middot; admin/all only</h3>' +
      '<div>Anno &middot; Q corrente: <b>' + state.year + ' &middot; ' + state.quarter + '</b></div>' +
      '<div>Project: <b>area-ccm-colloqui-personali</b></div>' +
      '<div>Path letto: <b>/schede/' + state.year + '/' + state.quarter + '</b></div>' +
      '<pre id="debugBranchDump">caricamento snapshot&hellip;</pre>' +
      '<div class="debug-actions">' +
        '<button class="debug-btn" onclick="reloadDebugDump()">Ricarica snapshot</button> ' +
        '<button class="debug-btn danger" onclick="wipeAllSchede()">Cancella TUTTE le schede ' + state.quarter + ' (test)</button>' +
      '</div>' +
    '</div>';
  reloadDebugDump();
}

window.reloadDebugDump = async function() {
  var el = document.getElementById('debugBranchDump');
  if (!el) return;
  el.textContent = 'caricamento snapshot…';
  var data = await Storage.readBranch(state.year, state.quarter);
  if (data === null) { el.textContent = '⚠ errore lettura Firebase'; return; }
  var summary = {};
  Object.entries(data).forEach(function(entry) {
    var slug = entry[0], tipi = entry[1];
    summary[slug] = {};
    Object.entries(tipi).forEach(function(e2) {
      var tipo = e2[0], scheda = e2[1];
      summary[slug][tipo] = {
        submittedAt: scheda.submittedAt ? new Date(scheda.submittedAt).toLocaleString('it-IT') : null,
        updatedAt:   scheda.updatedAt   ? new Date(scheda.updatedAt).toLocaleString('it-IT')   : null,
        ratings: {
          soft:  Object.keys(scheda.softSkills || {}).length,
          hard:  Object.keys(scheda.hardSkills || {}).length,
          kpi:   Object.keys(scheda.kpi || {}).length,
          ruota: Object.keys(scheda.ruota || {}).length
        }
      };
    });
  });
  el.textContent = Object.keys(summary).length === 0
    ? '(nessuna scheda salvata per ' + state.year + '/' + state.quarter + ')'
    : JSON.stringify(summary, null, 2);
};

window.wipeAllSchede = async function() {
  if (!confirm('Cancellare TUTTE le schede di ' + state.year + ' ' + state.quarter + '? Operazione non reversibile.')) return;
  try {
    await window.firebaseReady;
    await window.firebaseDB.remove(window.firebaseDB.ref('schede/' + state.year + '/' + state.quarter));
    Object.keys(localStorage).forEach(function(k) {
      if (k.indexOf('colloquiteam_cache/' + state.year + '/' + state.quarter + '/') === 0) localStorage.removeItem(k);
    });
    toast('Schede del trimestre cancellate');
    reloadDebugDump();
  } catch (err) {
    toast('Errore: ' + err.message);
  }
};

// ========================================================================
// PLACEHOLDER + TOAST + BOOT
// ========================================================================
function renderPlaceholder(title, sub) {
  document.getElementById('saveStatus').style.display = 'none';
  document.getElementById('appMain').innerHTML =
    '<div class="placeholder-page"><h2>' + title + '</h2><p>' + sub + '</p>' +
    '<p style="margin-top:24px;"><a href="#/home" class="btn-secondary">&larr; Torna alla home</a></p></div>';
}

function toast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(function() { t.classList.remove('show'); }, 2200);
}

init();
</script>

</body>
</html>
