            ${Array.from({length:11}, (_,i) => `<th>${i}</th>`).join('')}
          </tr>
        </thead>
        <tbody>
          ${RUOTA_MACRO.map((m, idx) => `
            <tr>
              <td class="macro-name"><b>${m.titolo}</b><span>${m.voci}</span></td>
              ${Array.from({length:11}, (_,v) => `
                <td>
                  <input type="radio" class="ruota-radio" name="ruota-${idx}" id="ruota-${idx}-${v}" value="${v}" data-field="ruota" data-idx="${idx}">
                  <label for="ruota-${idx}-${v}" aria-label="${v}"></label>
